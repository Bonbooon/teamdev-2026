@startuml
left to right direction
skinparam packageStyle rectangle

actor "メンバー" as Member
actor "マネージャー" as Manager

rectangle "TeamDev 2026" {

  package "共通ユースケース" {

    usecase "アカウント新規登録" as UC_Register
    usecase "ログイン" as UC_Login
    usecase "ログアウト" as UC_Logout

    usecase "プロフィール作成" as UC_ProfileCreate
    usecase "プロフィール参照" as UC_ProfileView
    usecase "プロフィール更新\n（LinkedIn・趣味・得意分野・在籍期間など）" as UC_ProfileUpdate

    usecase "Issue作成" as UC_IssueCreate
    usecase "Issue参照" as UC_IssueView
    usecase "Issue更新" as UC_IssueUpdate
    usecase "Issueにチームをアサイン" as UC_IssueAssignTeam
    usecase "Issueにメンバーをアサイン" as UC_IssueAssignMember

    usecase "Issueテンプレート参照" as UC_IssueTemplateView
    usecase "Issueテンプレート作成\n（開発チームがデフォルト提供）" as UC_IssueTemplateCreate
    usecase "Issueテンプレート更新" as UC_IssueTemplateUpdate
    usecase "Issueテンプレート削除" as UC_IssueTemplateDelete

    usecase "PJ詳細参照" as UC_ProjectView
    usecase "チーム詳細参照" as UC_TeamView

    usecase "Issue完了・PJ進捗更新" as UC_ProgressUpdate

    usecase "サーベイ回答" as UC_SurveyAnswer
    usecase "メンバー毎のサーベイ結果閲覧" as UC_SurveyResultView

    usecase "アラート受信" as UC_AlertReceive
    usecase "アラート解決" as UC_AlertResolve
  }

  package "マネージャー専用ユースケース" {

    usecase "PJ作成" as UC_ProjectCreate
    usecase "PJ概要更新" as UC_ProjectUpdate
    usecase "PJ削除" as UC_ProjectDelete
    usecase "PJ完了" as UC_ProjectComplete
    usecase "PJにチームを追加\n（1PJに複数チーム可）" as UC_ProjectAddTeam

    usecase "チーム作成" as UC_TeamCreate
    usecase "チーム概要更新" as UC_TeamUpdate
    usecase "チーム削除" as UC_TeamDelete
    usecase "チームにメンバーを追加" as UC_TeamAddMember
    usecase "チームメンバーを削除" as UC_TeamRemoveMember
    usecase "チームメンバーのステータス更新\n（休養中 / 稼働中 / 育休中 など）" as UC_TeamMemberStatus

    usecase "サーベイ配信設定\n（テンプレート選択・頻度・時間帯設定）" as UC_SurveyConfig
    usecase "PJ毎のサーベイ平均結果閲覧" as UC_ProjectSurveyView
    usecase "チーム毎のサーベイ結果閲覧" as UC_TeamSurveyView
  }
}

Member --> UC_Register
Member --> UC_Login
Member --> UC_Logout
Member --> UC_ProfileCreate
Member --> UC_ProfileView
Member --> UC_ProfileUpdate
Member --> UC_IssueCreate
Member --> UC_IssueView
Member --> UC_IssueUpdate
Member --> UC_IssueAssignTeam
Member --> UC_IssueAssignMember
Member --> UC_IssueTemplateView
Member --> UC_ProjectView
Member --> UC_TeamView
Member --> UC_ProgressUpdate
Member --> UC_SurveyAnswer
Member --> UC_SurveyResultView
Member --> UC_AlertReceive
Member --> UC_AlertResolve

Manager --> UC_ProjectCreate
Manager --> UC_ProjectUpdate
Manager --> UC_ProjectDelete
Manager --> UC_ProjectComplete
Manager --> UC_ProjectAddTeam
Manager --> UC_TeamCreate
Manager --> UC_TeamUpdate
Manager --> UC_TeamDelete
Manager --> UC_TeamAddMember
Manager --> UC_TeamRemoveMember
Manager --> UC_TeamMemberStatus
Manager --> UC_SurveyConfig
Manager --> UC_ProjectSurveyView
Manager --> UC_TeamSurveyView

@enduml