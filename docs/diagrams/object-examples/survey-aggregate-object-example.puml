@startuml
title Survey Aggregate - オブジェクト例（状態バリエーション）

left to right direction
skinparam shadowing false
skinparam objectAttributeIconSize 0

object "テンプレート: 週次コンディション" as template_weekly <<SurveyTemplate>> {
  id = "88888888-8888-8888-8888-888888888888"
  name = "週次コンディションサーベイ"
  description = "モチベーション・負荷の定点観測"
  createdAt = "2026-02-01T09:00:00+09:00"
}

object "質問1" as q1 <<SurveyQuestion>> {
  id = "88880001-8888-8888-8888-888888888888"
  surveyTemplateId = "88888888-8888-8888-8888-888888888888"
  question = "今週のコンディションはどうですか？"
  explanation = "直感で選択してください"
  position = 1
}

object "選択肢1-5" as q1opt5 <<SurveyQuestionOption>> {
  id = "88881005-8888-8888-8888-888888888888"
  surveyQuestionId = "88880001-8888-8888-8888-888888888888"
  label = "5: とても良い"
  position = 5
}

object "設定: チームA 週次" as setting_team_a <<SurveySetting>> {
  id = "89999999-9999-9999-9999-999999999999"
  teamId = "33333333-3333-3333-3333-333333333333"
  surveyTemplateId = "88888888-8888-8888-8888-888888888888"
  setterId = "11111111-1111-1111-1111-111111111111"
  recurringRule = "FREQ=WEEKLY;BYDAY=MON"
  createdAt = "2026-02-05T08:00:00+09:00"
}

object "配信時刻: 朝会前" as setting_time_1 <<SurveySettingTime>> {
  id = "89990001-9999-9999-9999-999999999999"
  surveySettingId = "89999999-9999-9999-9999-999999999999"
  deliveryTime = "09:00:00"
}

object "サーベイ: 鈴木（未回答）" as survey_unanswered <<Survey>> {
  id = "90000000-0000-0000-0000-000000000000"
  surveySettingId = "89999999-9999-9999-9999-999999999999"
  recipientId = "22222222-2222-2222-2222-222222222222"
  deliveredAt = "2026-03-02T09:00:00+09:00"
  lastAnsweredAt = null
  createdAt = "2026-03-02T09:00:00+09:00"
}

object "サーベイ: 佐藤（回答済み）" as survey_answered <<Survey>> {
  id = "90000000-0000-0000-0000-000000000001"
  surveySettingId = "89999999-9999-9999-9999-999999999999"
  recipientId = "11111111-1111-1111-1111-111111111111"
  deliveredAt = "2026-03-02T09:00:00+09:00"
  lastAnsweredAt = "2026-03-02T09:15:00+09:00"
  createdAt = "2026-03-02T09:00:00+09:00"
}

object "回答: Q1=5" as ans_q1 <<SurveyAnswer>> {
  surveyId = "90000000-0000-0000-0000-000000000001"
  surveyQuestionId = "88880001-8888-8888-8888-888888888888"
  selectedOptionId = "88881005-8888-8888-8888-888888888888"
  answeredAt = "2026-03-02T09:15:00+09:00"
}

object "チーム要約: 14日" as condition_summary_14 <<TeamConditionSummary>> {
  teamId = "33333333-3333-3333-3333-333333333333"
  windowDays = 14
  averageScore = 3.8
  responseRate = 0.86
}

object "履歴: 鈴木 30日" as condition_history_hanako <<MemberConditionHistory>> {
  teamMemberId = "44444444-4444-4444-4444-444444444444"
  windowDays = 30
}

object "スコア点1" as score_point_1 <<ConditionScorePoint>> {
  surveyId = "90000000-0000-0000-0000-000000000000"
  answeredAt = "2026-03-01T09:10:00+09:00"
  score = 2.4
}

object "スコア点2" as score_point_2 <<ConditionScorePoint>> {
  surveyId = "90000000-0000-0000-0000-000000000002"
  answeredAt = "2026-03-04T09:12:00+09:00"
  score = 3.1
}

object "チーム参照" as team_ref <<Team>> {
  id = "33333333-3333-3333-3333-333333333333"
  timeZone = "Asia/Tokyo"
}

template_weekly *-- q1
q1 *-- q1opt5
setting_team_a *-- setting_time_1
survey_answered *-- ans_q1
setting_team_a -- template_weekly
setting_team_a -- team_ref
survey_unanswered -- setting_team_a
survey_answered -- setting_team_a
team_ref -- condition_summary_14
condition_history_hanako *-- score_point_1
condition_history_hanako *-- score_point_2

note bottom
未回答/回答済みの2状態を同時に表現。
7/14/30/90日ウィンドウのうち 14日要約と30日履歴の例を表現。
配信時刻と回答時刻は Asia/Tokyo。
end note

@enduml