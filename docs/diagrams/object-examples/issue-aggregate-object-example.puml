  deadline = "2026-03-01T18:00:00+09:00"
  status = "done"
}

object "担当: 佐藤" as assignee_taro <<IssueAssignee>> {
  issueId = "66666666-6666-6666-6666-666666666666"
  teamMemberId = "43333333-3333-3333-3333-333333333333"
}

object "DoD: レビュー完了" as dod_review <<IssueDefinitionOfDone>> {
  id = "96666666-6666-6666-6666-666666666666"
  issueId = "68888888-8888-8888-8888-888888888888"
  description = "コードレビュー承認を得る"
}

object "DoD: E2E確認" as dod_e2e <<IssueDefinitionOfDone>> {
  id = "97777777-7777-7777-7777-777777777777"
  issueId = "68888888-8888-8888-8888-888888888888"
  description = "主要導線のE2Eテストを通過"
}

object "プロジェクト参照" as project_ref <<Project>> {
  id = "55555555-5555-5555-5555-555555555555"
  title = "TeamDev 2026 Phase1"
}

issue_in_progress *-- assignee_taro
issue_done *-- dod_review
issue_done *-- dod_e2e
issue_in_progress -- issue_in_review : parent-child
issue_in_progress -- project_ref
issue_in_review -- project_ref
issue_done -- project_ref

note bottom
in_progress / in_review / done の状態を同時に表現。
done には Definition of Done が存在する例を示す。
時刻は Asia/Tokyo。
end note

@enduml