  status = "in_review"
}

object "課題: 認証機能実装（完了）" as issue_done <<Issue>> {
  id = "68888888-8888-8888-8888-888888888888"
  projectId = "55555555-5555-5555-5555-555555555555"
  teamId = "33333333-3333-3333-3333-333333333333"
  parentIssueId = null
  issueTemplateId = "76666666-6666-6666-6666-666666666666"
